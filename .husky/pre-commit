pnpm lint-staged

# Rust checks (only if backend/ files are staged)
if git diff --cached --name-only | grep -q '^backend/'; then
  echo "Rust files staged — running cargo fmt --check and clippy..."
  (cd backend && cargo fmt --check && cargo clippy -p emailibrium -- -D warnings 2>&1 | grep -v "dead_code\|never used\|never constructed" || true)
fi
