#!/usr/bin/env bash
# Pre-commit gate — mirrors the GitHub CI workflow quality checks so
# violations are caught locally before they ever reach CI.
#
# Fails fast on the first error so the user gets back to a shell prompt
# instead of hanging. Missing tools = hard failure with an install hint.

set -euo pipefail

# 1) Prettier + ESLint on staged files (via lint-staged + package.json config).
pnpm lint-staged

# Collect staged files once, grouped by type.
staged() { git diff --cached --name-only --diff-filter=ACMR -- "$@"; }

mapfile -t STAGED_MD   < <(staged '*.md')
mapfile -t STAGED_YAML < <(staged '*.yaml' '*.yml')
mapfile -t STAGED_SH   < <(staged '*.sh')
HAS_BACKEND=$(staged 'backend/' | head -n1 || true)

# 2) Markdownlint (if .md staged).
if [ "${#STAGED_MD[@]}" -gt 0 ]; then
  if ! command -v markdownlint-cli2 >/dev/null 2>&1; then
    echo "✗ markdownlint-cli2 not installed. Run: npm i -g markdownlint-cli2" >&2
    exit 1
  fi
  echo "→ markdownlint on ${#STAGED_MD[@]} staged .md file(s)..."
  markdownlint-cli2 "${STAGED_MD[@]}"
fi

# 3) yamllint (if .yaml/.yml staged, excluding lockfiles).
if [ "${#STAGED_YAML[@]}" -gt 0 ]; then
  FILTERED=()
  for f in "${STAGED_YAML[@]}"; do
    case "$f" in
      *pnpm-lock.yaml) ;;
      *) FILTERED+=("$f") ;;
    esac
  done
  if [ "${#FILTERED[@]}" -gt 0 ]; then
    if ! command -v yamllint >/dev/null 2>&1; then
      echo "✗ yamllint not installed. Run: pip install yamllint" >&2
      exit 1
    fi
    echo "→ yamllint on ${#FILTERED[@]} staged YAML file(s)..."
    yamllint -c .yamllint.yaml "${FILTERED[@]}"
  fi
fi

# 4) shellcheck (if .sh staged).
if [ "${#STAGED_SH[@]}" -gt 0 ]; then
  if ! command -v shellcheck >/dev/null 2>&1; then
    echo "✗ shellcheck not installed. Run: brew install shellcheck" >&2
    exit 1
  fi
  echo "→ shellcheck on ${#STAGED_SH[@]} staged shell script(s)..."
  shellcheck "${STAGED_SH[@]}"
fi

# 5) Rust fmt + clippy (if backend/ touched). Matches CI strictness: deny
# all warnings but allow dead_code/unused_* so pre-existing noise doesn't
# block commits.
if [ -n "${HAS_BACKEND}" ]; then
  echo "→ cargo fmt + clippy on backend/..."
  (
    cd backend
    cargo fmt --package emailibrium -- --check
    cargo clippy -p emailibrium --all-targets -- \
      -D warnings \
      -A dead_code -A unused_variables -A unused_imports -A unused_mut
  )
fi

echo "✓ pre-commit checks passed."
